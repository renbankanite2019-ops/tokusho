# Shopify App credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Database (Supabase PostgreSQL)
# DATABASE_URL = Transaction pooler (port 6543) — アプリ実行時に使用。末尾に ?pgbouncer=true&connection_limit=1 を付ける
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL = Direct connection (port 5432) — migration に使用
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# App URL (set by `shopify app dev` automatically in dev)
SHOPIFY_APP_URL=https://your-ngrok-url.ngrok.io

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_session_secret_here
